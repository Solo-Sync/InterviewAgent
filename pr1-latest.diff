+            filler_by_type[ftype] = filler_by_type.get(ftype, 0) + 1
+        
+        return {
+            'total_duration': total_duration,
+            'char_count': len(semantic.segments),
+            'sentence_count': len(semantic.sentences),
+            'pause_count': len(features.pauses),
