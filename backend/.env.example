APP_ENV=dev
APP_NAME=Metacognitive Interview API
APP_VERSION=0.1.0
API_PREFIX=/api/v1
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/interview
AUTH_TOKEN_SECRET=dev-auth-secret
ACCESS_TOKEN_TTL_SECONDS=3600
ADMIN_LOGIN_EMAIL=admin@company.com
ADMIN_LOGIN_PASSWORD=password123
ANNOTATOR_LOGIN_EMAIL=annotator@company.com
ANNOTATOR_LOGIN_PASSWORD=password123
CANDIDATE_REGISTRY_PATH=data/candidates/dev_candidates.json
ALLOW_REMOTE_AUDIO_FETCH=false
REMOTE_AUDIO_MAX_BYTES=10485760
REMOTE_AUDIO_ALLOWED_HOSTS=

# LLM Gateway (Aliyun DashScope, 中国大陆)
LLM_GATEWAY_PROVIDER=aliyun
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com
# 指定评估使用的大模型名称（单模型）
LLM_MODEL_NAME=qwen-plus
